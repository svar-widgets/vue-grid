{
  "name": "@svar-ui/vue-grid",
  "version": "2.7.0",
  "description": "SVAR Vue Grid library",
  "productTag": "grid",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "BUILD_DEMOS=true vite build",
    "build:full-css": "BUILD_FULL_CSS=true vite build",
    "lint": "eslint . --report-unused-disable-directives",
    "preview": "vite preview",
    "prepare": "husky",
    "prettier": "prettier --write ./src/ ./demos/"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.es.js"
    },
    "./style.css": "./dist/index.css",
    "./all.css": "./dist-full/index.css"
  },
  "types": "./types/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "files": [
    "dist",
    "types",
    "package.json",
    "dist-full/index.css"
  ],
  "dependencies": {
    "@svar-ui/grid-locales": "2.7.0",
    "@svar-ui/grid-store": "2.7.0",
    "@svar-ui/lib-dom": "0.13.1",
    "@svar-ui/lib-state": "1.9.7",
    "@svar-ui/lib-vue": "1.1.0",
    "@svar-ui/vue-core": "2.6.0",
    "@svar-ui/vue-menu": "2.6.0",
    "@svar-ui/vue-toolbar": "2.6.0",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@svar-ui/core-locales": "2.6.0",
    "@svar-ui/grid-data-provider": "2.7.0",
    "@svar-ui/vue-comments": "2.6.0",
    "@svar-ui/vue-editor": "2.6.0",
    "@svar-ui/vue-filter": "2.5.0",
    "@svar-ui/vue-tasklist": "2.6.0",
    "eslint": "^9.35.0",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "vite": "^7.2.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^4.6.3"
  },
  "homepage": "https://svar.dev/vue/datagrid/",
  "repository": {
    "type": "git",
    "url": "https://github.com/svar-widgets/vue-grid.git"
  },
  "bugs": {
    "url": "https://forum.svar.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{ts,js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
